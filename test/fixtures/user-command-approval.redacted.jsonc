{
  "rules": {
    "allow": [
      {
        "match": "^(?:(?:/opt/homebrew/bin/)?(?:sim-use|xcodebuildmcp|asc|axe)|(?:/usr/bin/)?(?:xcodebuild|xcrun))(?:\\s|$).*",
        "scope": "segment",
        "priority": 100,
        "reason": "trusted iOS development tool"
      },
      {
        "match": "^(?:/usr/bin/)?swift\\s+(?:test|build)(?:\\s|$).*",
        "scope": "segment",
        "priority": 100,
        "reason": "trusted Swift package build or test"
      },
      {
        "match": "^(?:(?:/usr/bin/|/opt/homebrew/bin/)?git)(?:(?:\\s+-(?:C|c)(?:\\s+(?:'[^']*'|\"(?:\\\\.|[^\"\\\\])*\"|\\S+)|\\S+))|(?:\\s+--(?:no-pager|no-optional-locks|no-replace-objects|literal-pathspecs|glob-pathspecs|noglob-pathspecs|icase-pathspecs)))*\\s+commit(?:\\s|$).*",
        "scope": "segment",
        "priority": 100,
        "reason": "trusted git commit with validated location and signing options"
      }
    ]
  }
}
